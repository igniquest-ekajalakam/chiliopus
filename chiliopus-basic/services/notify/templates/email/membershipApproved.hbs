<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership Approved</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1 style="color: #1f7a1f;">Membership Approved</h1>
  <p>Hello {{name}},</p>
  <p>Your membership request has been approved.</p>
  <p><strong>Club:</strong> {{clubName}}</p>
  {{#if membershipNumber}}<p><strong>Membership Number:</strong> {{membershipNumber}}</p>{{/if}}
  {{#if remarks}}<p><strong>Remarks:</strong> {{remarks}}</p>{{/if}}
  <p style="margin-top: 24px;">
    <a href="{{dashboardUrl}}" style="background-color: #2563eb; color: #fff; padding: 10px 16px; text-decoration: none; border-radius: 6px; display: inline-block;">Open Dashboard</a>
  </p>
  <p style="margin-top: 30px; color: #6b7280;">Regards,<br>{{appName}}</p>
</body>
</html>

