<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Membership Request Update</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <h1 style="color: #b91c1c;">Membership Request Not Approved</h1>
  <p>Hello {{name}},</p>
  <p>Your membership request was not approved at this time.</p>
  <p><strong>Club:</strong> {{clubName}}</p>
  {{#if remarks}}<p><strong>Remarks:</strong> {{remarks}}</p>{{/if}}
  <p>Please contact support for help: {{supportEmail}}</p>
  <p style="margin-top: 30px; color: #6b7280;">Regards,<br>{{appName}}</p>
</body>
</html>

