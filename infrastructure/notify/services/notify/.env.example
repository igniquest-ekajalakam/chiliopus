# Server Configuration
PORT=3000

# API Security
API_KEY=super-secret-api-key-change-in-production

# SMTP Configuration
# Development: Use Google SMTP (Gmail)
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-gmail-app-password
#   SMTP_FROM=your-email@gmail.com
#
# Production: Use Postfix (leave SMTP_USER and SMTP_PASS empty)
SMTP_HOST=localhost
SMTP_PORT=25
SMTP_SECURE=false
# SMTP_USER=  # Leave empty for Postfix
# SMTP_PASS=  # Leave empty for Postfix
SMTP_FROM=no-reply@chiliopus.local

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL Configuration
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chiliopus
