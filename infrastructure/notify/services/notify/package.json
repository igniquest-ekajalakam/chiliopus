{
  "name": "chiliopus-notify",
  "version": "1.0.0",
  "description": "ChiliopusNotify - Centralized notification microservice for Chiliopus platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:worker": "ts-node-dev --respawn --transpile-only src/workers/email.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/email.worker.js",
    "lint": "eslint . --ext .ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "handlebars": "^4.7.8",
    "ioredis": "^5.3.2",
    "nodemailer": "^8.0.2",
    "pg": "^8.11.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.10.9",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
